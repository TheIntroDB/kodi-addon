<?xml version="1.0" encoding="UTF-8"?>
<settings>
    <category label="General">
        <setting id="auto_skip" type="bool" label="Auto-skip intros (no button)" default="false"/>
        <setting id="skip_offset" type="number" label="Extra seconds to skip past intro end" default="2"/>
    </category>
    <category label="TheIntroDB">
        <setting id="introdb_enabled" type="bool" label="Enable lookups" default="true"/>
        <setting id="introdb_api_key" type="text" label="Optional TheIntroDB API key" default=""/>
    </category>
    <category label="Debug">
        <setting id="debug_logging" type="bool" label="Verbose logging (kodi.log)" default="false"/>
        <setting id="debug_osd" type="bool" label="On-screen debug notifications" default="false"/>
    </category>
</settings>
